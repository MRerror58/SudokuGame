<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.sudokugame.controller.SudokuController"
            styleClass="root-pane"
            stylesheets="@sudoku.css"
            prefWidth="640" prefHeight="780" minWidth="580" minHeight="720">
    <top>
        <VBox alignment="CENTER" spacing="6" styleClass="header-box">
            <padding>
                <Insets top="22" right="20" bottom="18" left="20"/>
            </padding>
            <Label text="Sudoku 6×6" styleClass="title-label"/>
            <Label fx:id="statusLabel" text="" styleClass="status-label"/>
            <Label fx:id="feedbackLabel" text="" styleClass="feedback-label"/>
        </VBox>
    </top>
    <center>
        <StackPane fx:id="boardContainer" alignment="CENTER" styleClass="board-frame">
            <BorderPane.margin>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </BorderPane.margin>
            <GridPane fx:id="boardGrid" hgap="0" vgap="0" alignment="CENTER"/>
        </StackPane>
    </center>
    <bottom>
        <HBox alignment="CENTER" spacing="16">
            <padding>
                <Insets top="12" right="20" bottom="26" left="20"/>
            </padding>
            <Button fx:id="newGameButton" text="Nuevo juego" prefWidth="140" styleClass="action-button, primary-button"/>
            <Button fx:id="helpButton" text="Ayuda" prefWidth="110" styleClass="action-button, help-button"/>
            <Button fx:id="clearButton" text="Borrar celda" prefWidth="140" styleClass="action-button, clear-button"/>
        </HBox>
    </bottom>
</BorderPane>
